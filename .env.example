# Copy this to a private .env file in your runner environment.
# Do not commit real credentials, recipients, or completion history.

PULSE_CONFIG_PATH=./pulses.example.yaml
PULSE_STATE_PATH=./state/pulse-dev.json
PULSE_RUNNER_TIMEZONE=America/Los_Angeles

# Notification adapter examples. Leave blank for local demo mode.
PULSE_EMAIL_SMTP_HOST=
PULSE_EMAIL_SMTP_PORT=
PULSE_EMAIL_SMTP_USER=
PULSE_EMAIL_SMTP_PASSWORD=
PULSE_EMAIL_FROM=
PULSE_EMAIL_TO=
